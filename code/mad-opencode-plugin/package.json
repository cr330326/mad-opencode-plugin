{
  "name": "mad-opencode-plugin",
  "version": "0.1.2",
  "description": "MAD (Multi-Agent Dashboard) plugin for OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "opencode.example.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "opencode",
    "plugin",
    "multi-agent",
    "dashboard",
    "mad",
    "monitoring",
    "agent",
    "visualization"
  ],
  "author": "cr330326 <cr330326@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cr330326/mad-opencode-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/cr330326/mad-opencode-plugin/issues"
  },
  "homepage": "https://github.com/cr330326/mad-opencode-plugin#readme",
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
